<?xml version="1.0" encoding="utf-8" ?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Include>[MyCompany.MyProduct]*,[MyCompany.MyProduct.Api]*</Include>
					<Exclude>[MyCompany.MyProduct]*Migrations.*,[MyCompany.MyProduct.Api]*Program,</Exclude>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
